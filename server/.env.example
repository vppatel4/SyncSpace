# SyncSpace server — copy to .env
SYNCSPACE_DATABASE_URL="postgresql://syncspace:syncspace_dev@localhost:5433/syncspace?schema=public"
DATABASE_URL="${SYNCSPACE_DATABASE_URL}"

SYNCSPACE_JWT_SECRET="change-me-to-a-long-random-string-in-production"
SYNCSPACE_JWT_EXPIRES_IN="7d"

SYNCSPACE_PORT=4000
SYNCSPACE_CLIENT_ORIGIN="http://localhost:3000"

# Password reset — use Resend (recommended) and/or SMTP. Without either, local dev still works: the API returns
# the reset link in the JSON (forgot-password UI) and logs it to the console; production should set one of these.
#
# Resend — https://resend.com (API key + optional verified "from"; default onboarding@resend.dev works for testing)
# SYNCSPACE_RESEND_API_KEY="re_..."
# SYNCSPACE_RESEND_FROM="SyncSpace <onboarding@resend.dev>"
#
# SMTP alternative
# SYNCSPACE_SMTP_HOST="smtp.example.com"
# SYNCSPACE_SMTP_PORT=587
# SYNCSPACE_SMTP_SECURE="false"
# SYNCSPACE_SMTP_USER=""
# SYNCSPACE_SMTP_PASS=""
# SYNCSPACE_SMTP_FROM="noreply@yourdomain.com"
